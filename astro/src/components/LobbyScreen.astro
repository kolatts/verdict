---
---
<section id="screen-lobby" class="screen hidden">
  <header class="court-header">
    <h1>⚖️ Verdict</h1>
    <p class="room-code-display">Room: <span id="lobby-room-code">—</span></p>
  </header>

  <div class="card">
    <h2>Waiting for players…</h2>
    <p id="lobby-join-link" class="join-link"></p>
    <button id="btn-copy-link" class="btn btn-ghost btn-small">Copy join link</button>

    <div id="lobby-players" class="player-list"></div>
    <p id="lobby-status" class="status-text"></p>
    <div id="lobby-progress" class="progress-bar hidden"></div>

    <button id="btn-start" class="btn btn-primary hidden">Start the trial ⚖️</button>
  </div>
</section>
