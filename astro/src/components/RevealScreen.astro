---
---
<section id="screen-reveal" class="screen hidden">
  <header class="court-header small">
    <h1>⚖️ Verdict</h1>
    <span class="round-badge">
      Round <span id="reveal-round">1</span> of <span id="reveal-total">3</span>
    </span>
  </header>

  <div class="card take-card">
    <p class="take-label">The Hot Take</p>
    <blockquote id="reveal-take"></blockquote>
  </div>

  <div id="reveal-args" class="card"></div>
  <div id="reveal-contempt" class="card contempt-card hidden"></div>
  <div id="reveal-scores" class="card"></div>

  <div class="card">
    <button id="btn-next-round" class="btn btn-primary hidden">Next round →</button>
    <button id="btn-final" class="btn btn-primary hidden">See final leaderboard 🏆</button>
  </div>
</section>
